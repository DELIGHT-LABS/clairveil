# Clairveil DApp environment overrides.
# Copy to .env when you want shell-managed local overrides:
#   cp .env.example .env
#   set -a; source .env; set +a
#   npm start
#
# server.js still has safe local defaults, so you only need to set values
# that differ from the default local Clairveil profile.

# DApp server
CLAIRVEIL_DAPP_HOST=0.0.0.0
CLAIRVEIL_DAPP_PORT=5173
CLAIRVEIL_DAPP_LOCAL_TEST_MODE=1

# Local helper access.
# Keep these disabled unless you intentionally expose local-test helpers on LAN.
CLAIRVEIL_DAPP_ALLOW_LAN_SIGNING=0
CLAIRVEIL_DAPP_ALLOW_LAN_ADMIN=0

# Clairveil node / local CLI
CLAIRVEIL_HOME=/tmp/clairveil-dapp-local
CHAIN_ID=clairveil-local-2
CLAIRVEILD_BIN=clairveild
CLAIRVEIL_RPC=tcp://127.0.0.1:26657
CLAIRVEIL_REST=http://127.0.0.1:1317

# Browser-visible node endpoints.
# Leave empty to reuse CLAIRVEIL_RPC / CLAIRVEIL_REST.
CLAIRVEIL_PUBLIC_RPC=
CLAIRVEIL_PUBLIC_REST=

# Prover
CLAIRVEIL_PROVER_URL=http://127.0.0.1:8080
CLAIRVEIL_PUBLIC_PROVER_URL=http://127.0.0.1:8080
CLAIRVEIL_PROVER_BEARER_TOKEN=
CLAIRVEIL_PROVER_TIMEOUT_MS=120000

# Chain profile
CLAIRVEIL_TRANSPORT=cosmos
CLAIRVEIL_DENOM=uclair
CLAIRVEIL_DISPLAY_DENOM=CLAIR
CLAIRVEIL_COIN_DECIMALS=18
CLAIRVEIL_ACCOUNT_PREFIX=clair
CLAIRVEIL_SHIELDED_PREFIX=clairs
CLAIRVEIL_GAS_PRICES=1uclair

# Keplr / Cosmos profile
CLAIRVEIL_KEPLR_COIN_TYPE=118
CLAIRVEIL_KEPLR_GAS_LOW=1
CLAIRVEIL_KEPLR_GAS_AVERAGE=1
CLAIRVEIL_KEPLR_GAS_HIGH=1

# Optional EVM / MetaMask profile
CLAIRVEIL_EVM_RPC=http://127.0.0.1:8545
CLAIRVEIL_EVM_CHAIN_ID=815
CLAIRVEIL_EVM_CHAIN_NAME="EVM Localnet"
CLAIRVEIL_EVM_PRIVACY_PRECOMPILE=
CLAIRVEIL_EVM_GAS_LIMIT=0x989680
CLAIRVEIL_EVM_SEND_GAS_LIMIT=0x5208
