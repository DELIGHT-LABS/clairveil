{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/DELIGHT-LABS/clairveil/docs/schemas/clairveil-js-wallet-contract.schema.json",
  "title": "Clairveil JS/Web Wallet Contract Schemas",
  "description": "Machine-readable JSON Schema definitions for Clairveil wallet-facing conformance fixtures.",
  "$defs": {
    "schemaVersion": {
      "type": "string",
      "const": "v1"
    },
    "version": {
      "type": "string",
      "const": "v1"
    },
    "hexString": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]+$"
    },
    "hexStringMaybeEmpty": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]*$"
    },
    "hex32": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{64}$"
    },
    "hex20": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{40}$"
    },
    "transparentAddress": {
      "type": "string",
      "pattern": "^clair1[0-9a-z]+$"
    },
    "shieldedAddress": {
      "type": "string",
      "pattern": "^clairs1[0-9a-z]+$"
    },
    "amountString": {
      "type": "string",
      "pattern": "^[0-9]+$"
    },
    "denom": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9/:._-]{2,127}$"
    },
    "chainId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.:-]+$"
    },
    "policyName": {
      "type": "string",
      "enum": [
        "all-private",
        "amount",
        "to",
        "amount-to",
        "from",
        "amount-from",
        "from-to",
        "amount-from-to"
      ]
    },
    "disclosureModeName": {
      "type": "string",
      "enum": [
        "none",
        "public",
        "recipient-encrypted"
      ]
    },
    "disclosedFieldName": {
      "type": "string",
      "enum": [
        "amount",
        "asset_denom",
        "from_shielded_address",
        "to_shielded_address"
      ]
    },
    "merklePath": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/hexString"
      }
    },
    "merklePathHelper": {
      "type": "array",
      "items": {
        "type": "integer",
        "minimum": 0
      }
    },
    "transferInput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "amount",
        "randomness_hex",
        "spend_pubkey_hex",
        "view_pubkey_hex",
        "merkle_path",
        "merkle_path_helper",
        "note_hash_signature_hex",
        "nullifier_hex"
      ],
      "properties": {
        "amount": {
          "$ref": "#/$defs/amountString"
        },
        "randomness_hex": {
          "$ref": "#/$defs/hex32"
        },
        "spend_pubkey_hex": {
          "$ref": "#/$defs/hex32"
        },
        "view_pubkey_hex": {
          "$ref": "#/$defs/hex32"
        },
        "merkle_path": {
          "$ref": "#/$defs/merklePath"
        },
        "merkle_path_helper": {
          "$ref": "#/$defs/merklePathHelper"
        },
        "note_hash_signature_hex": {
          "$ref": "#/$defs/hexString"
        },
        "nullifier_hex": {
          "$ref": "#/$defs/hex32"
        }
      }
    },
    "transferOutput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "amount",
        "randomness_hex",
        "spend_pubkey_hex",
        "view_pubkey_hex",
        "commitment_hex"
      ],
      "properties": {
        "amount": {
          "$ref": "#/$defs/amountString"
        },
        "randomness_hex": {
          "$ref": "#/$defs/hex32"
        },
        "spend_pubkey_hex": {
          "$ref": "#/$defs/hex32"
        },
        "view_pubkey_hex": {
          "$ref": "#/$defs/hex32"
        },
        "commitment_hex": {
          "$ref": "#/$defs/hex32"
        }
      }
    },
    "preparedTransferPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "creator",
        "root_hex",
        "asset_id_hex",
        "inputs",
        "outputs",
        "cipher_text_hexes",
        "user_privacy_policy",
        "user_disclosure_mode",
        "audit_disclosure_digest_hex",
        "audit_disclosure_target_pubkey_hex",
        "audit_disclosure_payload_hex",
        "payload_hash"
      ],
      "properties": {
        "version": {
          "$ref": "#/$defs/version"
        },
        "creator": {
          "$ref": "#/$defs/transparentAddress"
        },
        "root_hex": {
          "$ref": "#/$defs/hex32"
        },
        "asset_id_hex": {
          "$ref": "#/$defs/hex32"
        },
        "inputs": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "$ref": "#/$defs/transferInput"
          }
        },
        "outputs": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "$ref": "#/$defs/transferOutput"
          }
        },
        "cipher_text_hexes": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "$ref": "#/$defs/hexString"
          }
        },
        "user_privacy_policy": {
          "type": "integer",
          "minimum": 0,
          "maximum": 7
        },
        "user_disclosure_mode": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2
        },
        "user_disclosure_digest_hex": {
          "$ref": "#/$defs/hex32"
        },
        "user_disclosure_target_pubkey_hex": {
          "$ref": "#/$defs/hex32"
        },
        "user_disclosure_payload_hex": {
          "$ref": "#/$defs/hexString"
        },
        "audit_disclosure_digest_hex": {
          "$ref": "#/$defs/hex32"
        },
        "audit_disclosure_target_pubkey_hex": {
          "$ref": "#/$defs/hex32"
        },
        "audit_disclosure_payload_hex": {
          "$ref": "#/$defs/hexString"
        },
        "payload_hash": {
          "$ref": "#/$defs/hex32"
        }
      }
    },
    "preparedWithdrawProverPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "root_hex",
        "nullifier_hex",
        "amount",
        "asset_denom",
        "asset_id_hex",
        "recipient",
        "recipient_bytes_hex",
        "chain_id",
        "expires_at_unix",
        "note_randomness_hex",
        "spend_pubkey_hex",
        "view_pubkey_hex",
        "merkle_path",
        "merkle_path_helper",
        "spend_note_hash_signature_hex",
        "payload_hash"
      ],
      "properties": {
        "version": {
          "$ref": "#/$defs/version"
        },
        "root_hex": {
          "$ref": "#/$defs/hex32"
        },
        "nullifier_hex": {
          "$ref": "#/$defs/hex32"
        },
        "amount": {
          "$ref": "#/$defs/amountString"
        },
        "asset_denom": {
          "$ref": "#/$defs/denom"
        },
        "asset_id_hex": {
          "$ref": "#/$defs/hex32"
        },
        "recipient": {
          "$ref": "#/$defs/transparentAddress"
        },
        "recipient_bytes_hex": {
          "$ref": "#/$defs/hex20"
        },
        "chain_id": {
          "$ref": "#/$defs/chainId"
        },
        "expires_at_unix": {
          "type": "integer",
          "minimum": 0
        },
        "note_randomness_hex": {
          "$ref": "#/$defs/hex32"
        },
        "spend_pubkey_hex": {
          "$ref": "#/$defs/hex32"
        },
        "view_pubkey_hex": {
          "$ref": "#/$defs/hex32"
        },
        "merkle_path": {
          "$ref": "#/$defs/merklePath"
        },
        "merkle_path_helper": {
          "$ref": "#/$defs/merklePathHelper"
        },
        "spend_note_hash_signature_hex": {
          "$ref": "#/$defs/hexString"
        },
        "payload_hash": {
          "$ref": "#/$defs/hex32"
        }
      }
    },
    "proof": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "payload_hash",
        "proof_hex"
      ],
      "properties": {
        "version": {
          "$ref": "#/$defs/version"
        },
        "payload_hash": {
          "$ref": "#/$defs/hex32"
        },
        "proof_hex": {
          "$ref": "#/$defs/hexString"
        }
      }
    },
    "proverExampleBundle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "transfer",
        "withdraw"
      ],
      "properties": {
        "schema_version": {
          "$ref": "#/$defs/schemaVersion"
        },
        "transfer": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "request",
            "response"
          ],
          "properties": {
            "request": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "version",
                "payload"
              ],
              "properties": {
                "version": {
                  "$ref": "#/$defs/version"
                },
                "payload": {
                  "$ref": "#/$defs/preparedTransferPayload"
                }
              }
            },
            "response": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "version",
                "proof"
              ],
              "properties": {
                "version": {
                  "$ref": "#/$defs/version"
                },
                "proof": {
                  "$ref": "#/$defs/proof"
                }
              }
            }
          }
        },
        "withdraw": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "validation_now_unix",
            "request",
            "response"
          ],
          "properties": {
            "validation_now_unix": {
              "type": "integer",
              "minimum": 0
            },
            "request": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "version",
                "payload"
              ],
              "properties": {
                "version": {
                  "$ref": "#/$defs/version"
                },
                "payload": {
                  "$ref": "#/$defs/preparedWithdrawProverPayload"
                }
              }
            },
            "response": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "version",
                "proof"
              ],
              "properties": {
                "version": {
                  "$ref": "#/$defs/version"
                },
                "proof": {
                  "$ref": "#/$defs/proof"
                }
              }
            }
          }
        }
      }
    },
    "routeContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method",
        "path",
        "request_version",
        "response_version"
      ],
      "properties": {
        "method": {
          "type": "string",
          "const": "POST"
        },
        "path": {
          "type": "string",
          "pattern": "^/v1/prover/(transfer|withdraw)$"
        },
        "request_version": {
          "$ref": "#/$defs/version"
        },
        "response_version": {
          "$ref": "#/$defs/version"
        }
      }
    },
    "proverHttpApiContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "content_type",
        "transfer_route",
        "withdraw_route",
        "error_response"
      ],
      "properties": {
        "schema_version": {
          "$ref": "#/$defs/schemaVersion"
        },
        "content_type": {
          "type": "string",
          "const": "application/json"
        },
        "transfer_route": {
          "$ref": "#/$defs/routeContract"
        },
        "withdraw_route": {
          "$ref": "#/$defs/routeContract"
        },
        "error_response": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "version",
            "codes"
          ],
          "properties": {
            "version": {
              "$ref": "#/$defs/version"
            },
            "codes": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "enum": [
                  "invalid_request",
                  "method_not_allowed",
                  "not_found",
                  "unauthorized",
                  "unavailable",
                  "proof_failed"
                ]
              }
            }
          }
        }
      }
    },
    "referenceFlowDisclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plane",
        "policy",
        "output_index",
        "commitment_hex",
        "digest_hex",
        "verified",
        "disclosed_fields",
        "amount",
        "asset_denom",
        "from_shielded_address",
        "to_shielded_address"
      ],
      "properties": {
        "plane": {
          "type": "string",
          "enum": [
            "user",
            "audit"
          ]
        },
        "policy": {
          "$ref": "#/$defs/policyName"
        },
        "output_index": {
          "type": "integer",
          "minimum": 0
        },
        "commitment_hex": {
          "$ref": "#/$defs/hex32"
        },
        "digest_hex": {
          "$ref": "#/$defs/hex32"
        },
        "verified": {
          "type": "boolean"
        },
        "disclosed_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/disclosedFieldName"
          }
        },
        "amount": {
          "$ref": "#/$defs/amountString"
        },
        "asset_denom": {
          "$ref": "#/$defs/denom"
        },
        "from_shielded_address": {
          "$ref": "#/$defs/shieldedAddress"
        },
        "to_shielded_address": {
          "$ref": "#/$defs/shieldedAddress"
        }
      }
    },
    "sendCapableReferenceFlow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "phase",
        "topology",
        "service",
        "transfer",
        "withdraw"
      ],
      "properties": {
        "schema_version": {
          "$ref": "#/$defs/schemaVersion"
        },
        "phase": {
          "type": "string",
          "const": "phase-a-send-capable"
        },
        "topology": {
          "type": "string",
          "const": "remote-sidecar-first"
        },
        "service": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "service_name",
            "default_listen_address",
            "health_path",
            "readiness_path",
            "transfer_path",
            "withdraw_path",
            "max_request_bytes"
          ],
          "properties": {
            "service_name": {
              "type": "string",
              "const": "clairveil-proverd"
            },
            "default_listen_address": {
              "type": "string"
            },
            "health_path": {
              "type": "string",
              "const": "/healthz"
            },
            "readiness_path": {
              "type": "string",
              "const": "/readyz"
            },
            "transfer_path": {
              "type": "string",
              "const": "/v1/prover/transfer"
            },
            "withdraw_path": {
              "type": "string",
              "const": "/v1/prover/withdraw"
            },
            "max_request_bytes": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "transfer": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "request_version",
            "response_version",
            "creator",
            "payload_hash",
            "proof_payload_hash",
            "msg_creator",
            "user_disclosure_mode",
            "user_privacy_policy",
            "user_disclosure",
            "audit_disclosure"
          ],
          "properties": {
            "request_version": {
              "$ref": "#/$defs/version"
            },
            "response_version": {
              "$ref": "#/$defs/version"
            },
            "creator": {
              "$ref": "#/$defs/transparentAddress"
            },
            "payload_hash": {
              "$ref": "#/$defs/hex32"
            },
            "proof_payload_hash": {
              "$ref": "#/$defs/hex32"
            },
            "msg_creator": {
              "$ref": "#/$defs/transparentAddress"
            },
            "user_disclosure_mode": {
              "$ref": "#/$defs/disclosureModeName"
            },
            "user_privacy_policy": {
              "$ref": "#/$defs/policyName"
            },
            "user_disclosure": {
              "$ref": "#/$defs/referenceFlowDisclosure"
            },
            "audit_disclosure": {
              "$ref": "#/$defs/referenceFlowDisclosure"
            }
          }
        },
        "withdraw": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "validation_now_unix",
            "request_version",
            "response_version",
            "payload_hash",
            "proof_payload_hash",
            "final_payload_hash",
            "amount",
            "asset_denom",
            "recipient",
            "chain_id",
            "expires_at_unix"
          ],
          "properties": {
            "validation_now_unix": {
              "type": "integer",
              "minimum": 0
            },
            "request_version": {
              "$ref": "#/$defs/version"
            },
            "response_version": {
              "$ref": "#/$defs/version"
            },
            "payload_hash": {
              "$ref": "#/$defs/hex32"
            },
            "proof_payload_hash": {
              "$ref": "#/$defs/hex32"
            },
            "final_payload_hash": {
              "$ref": "#/$defs/hex32"
            },
            "amount": {
              "type": "string",
              "pattern": "^[0-9]+[a-z][a-z0-9/:._-]{2,127}$"
            },
            "asset_denom": {
              "$ref": "#/$defs/denom"
            },
            "recipient": {
              "$ref": "#/$defs/transparentAddress"
            },
            "chain_id": {
              "$ref": "#/$defs/chainId"
            },
            "expires_at_unix": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },
    "rootSeedVector": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "address",
        "transparent_pubkey_hex",
        "signature_hex",
        "signing_message_hex",
        "root_seed_hex"
      ],
      "properties": {
        "address": {
          "$ref": "#/$defs/transparentAddress"
        },
        "transparent_pubkey_hex": {
          "$ref": "#/$defs/hexString"
        },
        "signature_hex": {
          "$ref": "#/$defs/hexString"
        },
        "signing_message_hex": {
          "$ref": "#/$defs/hexString"
        },
        "root_seed_hex": {
          "$ref": "#/$defs/hex32"
        }
      }
    },
    "identityVector": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "spend_scalar_hex",
        "spend_pubkey_hex",
        "view_scalar_hex",
        "view_pubkey_hex",
        "disclosure_scalar_hex",
        "disclosure_pubkey_hex",
        "shielded_address"
      ],
      "properties": {
        "spend_scalar_hex": {
          "$ref": "#/$defs/hex32"
        },
        "spend_pubkey_hex": {
          "$ref": "#/$defs/hex32"
        },
        "view_scalar_hex": {
          "$ref": "#/$defs/hex32"
        },
        "view_pubkey_hex": {
          "$ref": "#/$defs/hex32"
        },
        "disclosure_scalar_hex": {
          "$ref": "#/$defs/hex32"
        },
        "disclosure_pubkey_hex": {
          "$ref": "#/$defs/hex32"
        },
        "shielded_address": {
          "$ref": "#/$defs/shieldedAddress"
        }
      }
    },
    "walletGoldenVectors": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "sender_root_seed",
        "recipient_root_seed",
        "sender",
        "recipient",
        "note",
        "disclosure",
        "scan"
      ],
      "properties": {
        "schema_version": {
          "$ref": "#/$defs/schemaVersion"
        },
        "sender_root_seed": {
          "$ref": "#/$defs/rootSeedVector"
        },
        "recipient_root_seed": {
          "$ref": "#/$defs/rootSeedVector"
        },
        "sender": {
          "$ref": "#/$defs/identityVector"
        },
        "recipient": {
          "$ref": "#/$defs/identityVector"
        },
        "note": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "amount",
            "denom",
            "memo",
            "note_json_hex",
            "encrypted_note_hex",
            "commitment_hex",
            "nullifier_hex"
          ],
          "properties": {
            "amount": {
              "$ref": "#/$defs/amountString"
            },
            "denom": {
              "$ref": "#/$defs/denom"
            },
            "memo": {
              "type": "string"
            },
            "note_json_hex": {
              "$ref": "#/$defs/hexString"
            },
            "encrypted_note_hex": {
              "$ref": "#/$defs/hexString"
            },
            "commitment_hex": {
              "$ref": "#/$defs/hex32"
            },
            "nullifier_hex": {
              "$ref": "#/$defs/hex32"
            }
          }
        },
        "disclosure": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "policy",
            "mode",
            "payload_json_hex",
            "ciphertext_hex",
            "digest_hex"
          ],
          "properties": {
            "policy": {
              "$ref": "#/$defs/policyName"
            },
            "mode": {
              "$ref": "#/$defs/disclosureModeName"
            },
            "payload_json_hex": {
              "$ref": "#/$defs/hexString"
            },
            "ciphertext_hex": {
              "$ref": "#/$defs/hexString"
            },
            "digest_hex": {
              "$ref": "#/$defs/hex32"
            }
          }
        },
        "scan": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "tx_hash_hex",
            "height"
          ],
          "properties": {
            "tx_hash_hex": {
              "$ref": "#/$defs/hexString"
            },
            "height": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },
    "showAddressResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from_address",
        "address",
        "derived_from",
        "usage"
      ],
      "properties": {
        "from_address": {
          "$ref": "#/$defs/transparentAddress"
        },
        "address": {
          "$ref": "#/$defs/shieldedAddress"
        },
        "derived_from": {
          "type": "string",
